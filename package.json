{
  "name": "srg",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run build && ng serve",
    "build": "node $npm_execpath run parse-pages && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "parse-pages": "node ./parse-pages.js",
    "github-build": "node $npm_execpath run parse-pages && ng build --configuration production --base-href 'https://hlzlmgrmt.github.io/srg/'",
    "github-deploy": "npx angular-cli-ghpages --dir=dist/srg/browser --no-silent"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@angular/localize": "^21.2.7",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}